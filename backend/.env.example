# Required
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/churnshield
REDIS_URL=redis://localhost:6379

# Optional — set this to enable LLM-generated messages instead of templates
# Get your key at console.anthropic.com (minimum $5 credit)
# The app works fully without this — smart templates are used as fallback
ANTHROPIC_API_KEY=your-key-here
